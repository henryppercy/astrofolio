---
import { DateTime } from 'luxon';
import Layout from '../layouts/Layout.astro';

export const prerender = true;

import { getCollection } from 'astro:content';

const posts = await getCollection('post');
const books = await getCollection('book');

const recent = books
    .filter(book => !!book.data.date_finished)
    .toSorted((a, b) => 
        DateTime.fromJSDate(b.data.date_finished).toMillis() - 
        DateTime.fromJSDate(a.data.date_finished).toMillis()
    )
    .slice(0, 5);

const currentlyReading = books.filter(book => !book.data.date_finished)[0];
const now = DateTime.now();

const readThisYear = books.filter((book) => {
    if (book.data.date_finished) {
        return DateTime.fromJSDate(book.data.date_finished).year == now.year;
    }
});
---

<Layout title="Henry Percy">
	<main class="space-y-5 prose prose-stone dark:prose-invert max-w-3xl mx-auto">
		<h1 class="mb-4 text-3xl font-bold leading-none tracking-tight md:text-4xl">Henry</h1>
        <p>Hey, I'm a <span class="font-semibold">Software Developer</span> based in <span class="font-semibold">London</span>. On this site I like to write about life, track my Spanish learning progress, and log what I'm reading.</p>
        <section>
            <h2>Reading</h2>
            <p>
                I've been reading more and more over the past few years and so far this year I've read <span class="font-semibold">{ readThisYear.length }</span> book{ readThisYear.length !== 1 ? 's' : '' }. Most recently I've read:
            </p>
            <ul class="not-prose space-y-3">
                {recent.map(book => (
                    <li class="text-sm">
                        <span class="text-neutral-500 dark:text-neutral-400">{book.data.author}</span>
                        <span class="mx-1.5 text-neutral-400 dark:text-neutral-600">—</span>
                        <span class="italic">{book.data.title}</span>
                        {book.data.rating && (
                            <span class="ml-2 text-neutral-400 dark:text-neutral-600 tabular-nums text-xs">{book.data.rating}/5</span>
                        )}
                    </li>
                ))}
                <li>
                    <a href="/books" class="group inline-flex items-center gap-1.5 font-medium text-sm hover:text-stone-900 hover:dark:text-stone-50 transition-colors">
                        See full reading list
                        <span class="transition-transform group-hover:translate-x-0.5">→</span>
                    </a>
                </li>
            </ul>
            <p>{currentlyReading ? <> I'm currently reading <span class="font-semibold italic">{ currentlyReading.data.title }</span> by <span class="font-semibold">{ currentlyReading.data.author }</span>.</> : ''}</p>
        </section>

		<section>
			<h2>Writing</h2>
			<ul class="not-prose space-y-3">
				{posts
					.filter(post => post.data.is_published)
					.sort((a, b) => new Date(b.data.created_at).getTime() - new Date(a.data.created_at).getTime())
					.slice(0, 3)
					.map(post => (
						<li>
							<a href={`posts/${post.slug}`} class="group font-medium inline-flex justify-between w-full items-baseline gap-4 sm:inline-flex sm:gap-5">
								<p transition:name={`post-title-${post.slug}`} class="flex-none max-sm:w-2/3 group-hover:text-stone-900 group-hover:dark:text-stone-50 transition-colors">{post.data.title}</p>
								<span class="m-0 hidden flex-1 sm:block border-t border-dashed border-neutral-300 dark:border-neutral-700"></span>
								<span class="flex-none font-mono text-xs tabular-nums">
									<time datetime={String(post.data.created_at)}>{post.data.created_at.toLocaleDateString('en-US', { month: 'short', day: '2-digit', year: 'numeric' })}</time>
								</span>
							</a>
						</li>
					)
				)}
                <li>
                    <a href="/posts" class="group inline-flex items-center gap-1.5 font-medium text-sm hover:text-stone-900 hover:dark:text-stone-50 transition-colors">
                        See all posts
                        <span class="transition-transform group-hover:translate-x-0.5">→</span>
                    </a>
                </li>
			</ul>
		</section>
	</main>
</Layout>
