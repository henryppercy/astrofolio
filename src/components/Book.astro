---
import Badge from './Badge.astro';
import type { DateTime } from "luxon";

const { book } = Astro.props;

function formatDate(date: DateTime): string {
    return date.toFormat('yyyy-MM-dd');
}

function daysBetween(start: DateTime, end: DateTime): number {
    return Math.round(end.diff(start, 'days').days) + 1;
}

function getPace(start: DateTime, end: DateTime, pageCount: number): number | null {
    if (!start || !end || !pageCount) return null;
    const days = daysBetween(start, end);
    return Math.round(pageCount / Math.max(1, days));
}
---

<li class="grid grid-cols-1 sm:grid-cols-[160px_1fr] items-start rounded max-sm:gap-y-6 group py-8 px-0">
    <div class="flex items-center justify-center h-full">
        <img
            src={book.data.image_url}
            alt={book.data.title}
            class="block h-full w-full object-fit max-sm:rounded sm:rounded not-prose"
        />
    </div>
    <div class="sm:pl-6 flex flex-col justify-between h-full">
        <div class="space-y-2">
            <div class="flex justify-between">
                <div>
                    <h3 class="font-bold flex gap-x-2 items-baseline text-pretty m-0">
                        {book.data.title}
                    </h3>
                    <p class="text-sm m-0">
                        {book.data.author}
                    </p>
                    {book.data.headline && (
                        <p class="text-xs text-neutral-500 m-0 mt-1 italic">{book.data.headline}</p>
                    )}
                    {book.data.series && (
                        <p class="text-xs text-neutral-500 m-0 mt-1">
                            {book.data.series}{book.data.series_pos ? ` #${book.data.series_pos}` : ''}
                        </p>
                    )}
                </div>
                {book.data.rating &&
                    <div class="mt-1">
                        <Badge
                            color={
                                book.data.rating >= 5 ? "emerald"
                                : book.data.rating >= 4 ? "green"
                                : book.data.rating >= 3 ? "lime"
                                : book.data.rating >= 2 ? "yellow"
                                : "red"
                            }
                        >
                            {book.data.rating}
                        </Badge>
                    </div>
                }
            </div>
            <dl class="grid sm:grid-cols-[max-content_1fr] gap-x-4 gap-y-2 text-sm md:text-xs">
                <dt class="m-0 font-semibold">Start Date</dt>
                <dd class="m-0 tabular-nums text-neutral-600 dark:text-neutral-400 not-prose">
                    {book.data.date_started ? formatDate(book.data.date_started) : '—'}
                </dd>
                <dt class="m-0 font-semibold">Finish Date</dt>
                <dd class="m-0 tabular-nums text-neutral-600 dark:text-neutral-400 not-prose">
                    {book.data.date_finished ? (
                        <>
                            {formatDate(book.data.date_finished)}
                            {book.data.date_started && (
                                <span class="text-neutral-500"> ({daysBetween(book.data.date_started, book.data.date_finished)} {daysBetween(book.data.date_started, book.data.date_finished) === 1 ? ' day' : ' days'})</span>
                            )}
                        </>
                    ) : '—'}
                </dd>
                <dt class="m-0 font-semibold">Release Date</dt>
                <dd class="m-0 tabular-nums text-neutral-600 dark:text-neutral-400 not-prose">
                    {book.data.date_published ? formatDate(book.data.date_published) : '—'}
                </dd>
                {book.data.page_count > 0 && (
                    <>
                        <dt class="m-0 font-semibold">Pages</dt>
                        <dd class="m-0 tabular-nums text-neutral-600 dark:text-neutral-400 not-prose">
                            {book.data.page_count.toLocaleString()}
                            {book.data.date_finished && getPace(book.data.date_started, book.data.date_finished, book.data.page_count) && (
                                <span class="text-neutral-500"> ({getPace(book.data.date_started, book.data.date_finished, book.data.page_count)} pages per day)</span>
                            )}
                        </dd>
                    </>
                )}
                <dt class="m-0 font-semibold">Format</dt>
                <dd class="m-0 tabular-nums text-neutral-600 dark:text-neutral-400 not-prose">
                    {book.data.format || '—'}
                </dd>
            </dl>
        </div>
        <div class="flex items-center gap-x-2 text-xs/5 text-stone-500 pt-1.5">
            <p class="m-0 overflow-hidden whitespace-nowrap text-xs/5 text-stone-500 not-prose">{book.data.genre}</p>
            {book.data.tags?.length > 0 && book.data.tags.slice(0, 4).map((tag: string) => (
                <>
                    <svg viewBox="0 0 2 2" class="size-0.5 fill-current">
                        <circle cx="1" cy="1" r="1" />
                    </svg>
                    <p class="m-0 overflow-hidden whitespace-nowrap text-xs/5 text-stone-500 not-prose">{tag}</p>
                </>
            ))}
        </div>
    </div>
</li>
